Sub RefreshDashboard()
    Dim wsh As Object
    Dim waitOnReturn As Boolean
    Dim windowStyle As Integer
    Dim errorCode As Integer
    Dim projectPath As String
    Dim conn As WorkbookConnection

    ' --- CONFIGURATION ---
    ' Set this to the exact folder path where run_live_github.py lives
    projectPath = "C:\Users\caser\PycharmProjects\Dashboard Testing"
    ' ---------------------

    Set wsh = CreateObject("WScript.Shell")
    waitOnReturn = True ' Pause Excel until Python finishes extracting data
    windowStyle = 1     ' Show the command prompt (use 0 to hide it)

    ' 1. Run the Python script
    errorCode = wsh.Run("cmd.exe /c cd /d """ & projectPath & """ && python run_live_github.py", windowStyle, waitOnReturn)

    If errorCode = 0 Then
        ' 2. Disable Background Refresh on all Power Query connections
        ' (This forces Excel to completely finish loading the data before moving on)
        For Each conn In ThisWorkbook.Connections
            If conn.Type = xlConnectionTypeOLEDB Then
                conn.OLEDBConnection.BackgroundQuery = False
            ElseIf conn.Type = xlConnectionTypeODBC Then
                conn.ODBCConnection.BackgroundQuery = False
            End If
        Next conn

        ' 3. Now that background loading is disabled, refresh all tables!
        ThisWorkbook.RefreshAll

        ' 4. Tell the user it worked (this box won't appear until the data is fully loaded!)
        MsgBox "Dashboard updated successfully with live GitHub data!", vbInformation, "Success"
    Else
        ' Tell the user if Python crashed (e.g., no internet, bad token)
        MsgBox "Error: The data extraction script failed to run. Check your internet or GitHub token.", vbCritical, "Update Failed"
    End If

    Set wsh = Nothing
End Sub


